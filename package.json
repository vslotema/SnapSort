{
  "name": "snapsort",
  "version": "0.1.0",
  "description": "AI-powered file organizer with non-destructive preview",
  "main": "app/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron app/main/index.js\"",
    "electron:build": "npm run build && electron-builder"
  },
  "keywords": [
    "electron",
    "vue",
    "ai",
    "file-organizer"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-devtools-installer": "^4.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "mime-types": "^2.1.35",
    "pinia": "^2.1.7",
    "sql.js": "^1.10.3",
    "vue": "^3.4.0",
    "vue-feather": "^2.0.0",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.5.0"
  }
}
